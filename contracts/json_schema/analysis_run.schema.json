{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/analysis_run.schema.json",
  "title": "MarketCell AnalysisRun",
  "type": "object",
  "required": [
    "run_id",
    "target",
    "horizon",
    "engine_version",
    "input_hash",
    "input_snapshot",
    "formula_versions",
    "cell_manifests",
    "status",
    "started_at",
    "schema_version",
    "finished_at",
    "report_id",
    "error",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "horizon": {
      "type": "string",
      "minLength": 1
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "input_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_snapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "formula_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "cell_manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "enum": ["running", "succeeded", "failed"]
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "analysis_run.v1"
    },
    "finished_at": {
      "type": ["string", "null"]
    },
    "report_id": {
      "type": ["string", "null"]
    },
    "error": {
      "type": ["string", "null"]
    },
    "metadata": {
      "$ref": "#/$defs/run_metadata"
    }
  },
  "$defs": {
    "run_metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cell_execution_plan": {
          "type": "object",
          "required": ["plan_id", "schema_version", "nodes", "service_bindings"],
          "additionalProperties": true,
          "properties": {
            "plan_id": {
              "type": "string",
              "minLength": 1
            },
            "schema_version": {
              "enum": ["cell_execution_plan.v1", "cell_execution_plan.v2"]
            },
            "nodes": {
              "type": "array"
            },
            "service_bindings": {
              "type": "array"
            }
          }
        },
        "cell_runtime_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cell_runtime_trace"
          }
        },
        "cell_runtime_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cell_runtime_summary"
          }
        },
        "execution_plan_validation": {
          "$ref": "https://marketcell.local/schemas/execution_plan_validation.schema.json"
        },
        "data_sources": {
          "$ref": "#/$defs/data_source_audit"
        }
      }
    },
    "cell_runtime_trace": {
      "type": "object",
      "required": [
        "trace_id",
        "span_id",
        "run_id",
        "node_id",
        "cell_id",
        "formula_version",
        "status",
        "started_at",
        "finished_at",
        "duration_ms",
        "schema_version",
        "plan_id",
        "implementation_id",
        "service_id",
        "runtime",
        "retry_count",
        "error",
        "parent_span_id",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "span_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "cell_id": {
          "type": "string",
          "minLength": 1
        },
        "formula_version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["succeeded", "failed", "skipped"]
        },
        "started_at": {
          "type": "string",
          "minLength": 1
        },
        "finished_at": {
          "type": "string",
          "minLength": 1
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "schema_version": {
          "const": "cell_runtime_trace.v1"
        },
        "plan_id": {
          "type": ["string", "null"]
        },
        "implementation_id": {
          "type": ["string", "null"]
        },
        "service_id": {
          "type": ["string", "null"]
        },
        "runtime": {
          "type": ["string", "null"],
          "enum": ["python_local", "python_service", "rust_service", "external_service", null]
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": ["string", "null"]
        },
        "parent_span_id": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "cell_runtime_summary": {
      "type": "object",
      "required": [
        "cell_id",
        "formula_version",
        "implementation_id",
        "service_id",
        "runtime",
        "trace_count",
        "succeeded_count",
        "failed_count",
        "skipped_count",
        "average_duration_ms",
        "max_duration_ms",
        "min_duration_ms",
        "p95_duration_ms",
        "error_count",
        "retry_count",
        "schema_version"
      ],
      "additionalProperties": false,
      "properties": {
        "cell_id": {
          "type": "string",
          "minLength": 1
        },
        "formula_version": {
          "type": "string",
          "minLength": 1
        },
        "implementation_id": {
          "type": ["string", "null"]
        },
        "service_id": {
          "type": ["string", "null"]
        },
        "runtime": {
          "type": ["string", "null"],
          "enum": ["python_local", "python_service", "rust_service", "external_service", null]
        },
        "trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "succeeded_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "max_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "min_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "p95_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "schema_version": {
          "const": "cell_runtime_summary.v1"
        }
      }
    },
    "data_source_audit": {
      "type": "object",
      "required": ["provider_selection_plan", "router_plan"],
      "additionalProperties": true,
      "properties": {
        "provider_selection_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/provider_selection_plan"
            },
            {
              "type": "null"
            }
          ]
        },
        "router_plan": {
          "$ref": "#/$defs/router_plan"
        }
      }
    },
    "provider_selection_plan": {
      "type": "object",
      "required": ["primary", "backups", "disabled", "candidates"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "anyOf": [
            {
              "$ref": "#/$defs/provider_selection_candidate"
            },
            {
              "type": "null"
            }
          ]
        },
        "backups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_selection_candidate"
          }
        },
        "disabled": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_selection_candidate"
          }
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_selection_candidate"
          }
        }
      }
    },
    "provider_selection_candidate": {
      "type": "object",
      "required": [
        "provider",
        "tier",
        "role",
        "selection_score",
        "health_score",
        "business_priority",
        "score_components",
        "reason_codes",
        "profile",
        "reliability"
      ],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["primary", "backup", "disabled"]
        },
        "selection_score": {
          "type": "number"
        },
        "health_score": {
          "type": ["number", "null"]
        },
        "business_priority": {
          "type": "number"
        },
        "score_components": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profile": {
          "$ref": "#/$defs/source_profile"
        },
        "reliability": {
          "anyOf": [
            {
              "$ref": "#/$defs/provider_reliability"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "router_plan": {
      "type": "object",
      "required": ["entries", "disabled", "missing_providers", "ignored_providers"],
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/router_plan_entry"
          }
        },
        "disabled": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/provider_selection_candidate"
          }
        },
        "missing_providers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ignored_providers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "router_plan_entry": {
      "type": "object",
      "required": ["provider", "role", "selection_score", "reason_codes", "profile", "candidate"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["primary", "backup", "disabled"]
        },
        "selection_score": {
          "type": "number"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profile": {
          "$ref": "#/$defs/source_profile"
        },
        "candidate": {
          "$ref": "#/$defs/provider_selection_candidate"
        }
      }
    },
    "source_profile": {
      "type": "object",
      "required": [
        "provider",
        "tier",
        "description",
        "supports_realtime",
        "supports_history",
        "requires_api_key"
      ],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "supports_realtime": {
          "type": "boolean"
        },
        "supports_history": {
          "type": "boolean"
        },
        "requires_api_key": {
          "type": "boolean"
        }
      }
    },
    "provider_reliability": {
      "type": "object",
      "required": [
        "source_provider",
        "trend_point_count",
        "record_count",
        "average_health_score",
        "latest_health_score",
        "worst_health_score",
        "health_grade",
        "affected_symbols",
        "affected_horizons",
        "severity_counts",
        "issue_counts",
        "first_window_start",
        "last_window_start"
      ],
      "additionalProperties": false,
      "properties": {
        "source_provider": {
          "type": "string",
          "minLength": 1
        },
        "trend_point_count": {
          "type": "integer",
          "minimum": 0
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_health_score": {
          "type": "number"
        },
        "latest_health_score": {
          "type": "number"
        },
        "worst_health_score": {
          "type": "number"
        },
        "health_grade": {
          "enum": ["excellent", "good", "degraded", "poor"]
        },
        "affected_symbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_horizons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "issue_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "first_window_start": {
          "type": ["string", "null"]
        },
        "last_window_start": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
