{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/performance_benchmark_result.schema.json",
  "title": "MarketCell PerformanceBenchmarkResult",
  "type": "object",
  "required": [
    "benchmark_id",
    "baseline_schema_version",
    "input_hash",
    "warmup_runs",
    "measured_runs",
    "expected_node_count",
    "thresholds",
    "reference_measurement",
    "total_durations",
    "nodes",
    "slowest_node_id",
    "actual_decision",
    "actual_formula_versions",
    "correctness_failures",
    "performance_failures",
    "environment",
    "created_at",
    "passed",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline_schema_version": {
      "const": "performance_baseline.v1"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "warmup_runs": {
      "type": "integer",
      "minimum": 0
    },
    "measured_runs": {
      "type": "integer",
      "minimum": 1
    },
    "expected_node_count": {
      "type": "integer",
      "minimum": 1
    },
    "thresholds": {
      "type": "object",
      "required": ["total_p95_ms", "node_p95_ms", "rationale"],
      "additionalProperties": false,
      "properties": {
        "total_p95_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "node_p95_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reference_measurement": {
      "type": "object",
      "required": [
        "environment",
        "measured_at",
        "total_p95_ms",
        "slowest_node_p95_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "measured_at": {
          "type": "string",
          "minLength": 1
        },
        "total_p95_ms": {
          "type": "number",
          "minimum": 0
        },
        "slowest_node_p95_ms": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "total_durations": {
      "$ref": "#/$defs/duration_distribution"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node_performance"
      }
    },
    "slowest_node_id": {
      "type": ["string", "null"]
    },
    "actual_decision": {
      "type": "object",
      "additionalProperties": true
    },
    "actual_formula_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "correctness_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    },
    "performance_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "performance_benchmark_result.v1"
    }
  },
  "$defs": {
    "duration_distribution": {
      "type": "object",
      "required": [
        "sample_count",
        "average_ms",
        "min_ms",
        "p50_ms",
        "p95_ms",
        "p99_ms",
        "max_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "sample_count": {
          "type": "integer",
          "minimum": 1
        },
        "average_ms": {
          "type": "number",
          "minimum": 0
        },
        "min_ms": {
          "type": "number",
          "minimum": 0
        },
        "p50_ms": {
          "type": "number",
          "minimum": 0
        },
        "p95_ms": {
          "type": "number",
          "minimum": 0
        },
        "p99_ms": {
          "type": "number",
          "minimum": 0
        },
        "max_ms": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "node_performance": {
      "type": "object",
      "required": ["node_id", "cell_id", "durations"],
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "cell_id": {
          "type": "string",
          "minLength": 1
        },
        "durations": {
          "$ref": "#/$defs/duration_distribution"
        }
      }
    },
    "failure": {
      "type": "object",
      "required": ["code", "message", "actual", "expected"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "actual": true,
        "expected": true
      }
    }
  }
}
