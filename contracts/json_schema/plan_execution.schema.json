{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/plan_execution.schema.json",
  "title": "MarketCell PlanExecution",
  "type": "object",
  "required": [
    "schema_version",
    "coordinator",
    "plan_id",
    "root_node_id",
    "status",
    "execution_order",
    "completed_node_ids",
    "failed_node_id",
    "error"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "plan_execution.v1"
    },
    "coordinator": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "root_node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["succeeded", "failed"]
    },
    "execution_order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completed_node_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failed_node_id": {
      "type": ["string", "null"]
    },
    "error": {
      "type": ["string", "null"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        }
      },
      "then": {
        "properties": {
          "failed_node_id": {
            "type": "null"
          },
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "properties": {
          "failed_node_id": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
