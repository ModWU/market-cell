{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/analysis_request.schema.json",
  "title": "MarketCell AnalysisRequest",
  "type": "object",
  "required": ["target", "horizon", "candles"],
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "string",
      "minLength": 1
    },
    "horizon": {
      "type": "string",
      "minLength": 1
    },
    "candles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candle"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/market_event"
      },
      "default": []
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "candle": {
      "type": "object",
      "required": ["timestamp", "open", "high", "low", "close", "volume"],
      "additionalProperties": false,
      "properties": {
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "open": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "high": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "low": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "close": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "volume": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "market_event": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "default": "general"
        },
        "sentiment": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "default": 0
        },
        "impact": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0
        },
        "freshness": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        }
      }
    }
  }
}
