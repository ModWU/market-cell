{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/cell_graph_definition.schema.json",
  "title": "MarketCell CellGraphDefinition",
  "type": "object",
  "required": [
    "graph_id",
    "graph_version",
    "name",
    "root_node_id",
    "nodes",
    "organs",
    "description",
    "schema_version",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_version": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "root_node_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "organs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/organ"
      }
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "const": "cell_graph_definition.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "node_id",
        "cell_id",
        "execution_role",
        "dependencies",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "cell_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_role": {
          "enum": ["leaf", "aggregator", "root"]
        },
        "dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "organ": {
      "type": "object",
      "required": [
        "organ_id",
        "organ_version",
        "name",
        "node_ids",
        "output_node_ids",
        "description",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "organ_id": {
          "type": "string",
          "minLength": 1
        },
        "organ_version": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
