{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/execution_control_record.schema.json",
  "title": "MarketCell ExecutionControlRecord",
  "type": "object",
  "required": [
    "control_id",
    "idempotency_key",
    "run_id",
    "plan_id",
    "node_id",
    "primary_binding_id",
    "fallback_binding_ids",
    "status",
    "attempts",
    "retry_count",
    "fallback_count",
    "final_binding_id",
    "final_failure_kind",
    "started_at",
    "finished_at",
    "schema_version",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "control_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "primary_binding_id": {
      "type": "string",
      "minLength": 1
    },
    "fallback_binding_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": ["succeeded", "failed", "canceled"]
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/attempt"
      }
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "fallback_count": {
      "type": "integer",
      "minimum": 0
    },
    "final_binding_id": {
      "type": "string",
      "minLength": 1
    },
    "final_failure_kind": {
      "type": ["string", "null"],
      "enum": [
        "routing",
        "dispatch",
        "execution",
        "timeout",
        "backpressure",
        "canceled",
        "contract",
        null
      ]
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "finished_at": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "execution_control_record.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        }
      },
      "then": {
        "properties": {
          "final_failure_kind": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "canceled"
          }
        }
      },
      "then": {
        "properties": {
          "final_failure_kind": {
            "const": "canceled"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "properties": {
          "final_failure_kind": {
            "enum": [
              "routing",
              "dispatch",
              "execution",
              "timeout",
              "backpressure",
              "contract"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "attempt": {
      "type": "object",
      "required": [
        "attempt_id",
        "idempotency_key",
        "attempt_number",
        "binding_attempt_number",
        "fallback_index",
        "binding_id",
        "is_retry",
        "status",
        "failure_kind",
        "retryable",
        "started_at",
        "finished_at",
        "duration_ms",
        "trace_span_id",
        "actual_implementation_id",
        "actual_service_id",
        "actual_runtime",
        "error",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "type": "string",
          "minLength": 1
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "attempt_number": {
          "type": "integer",
          "minimum": 1
        },
        "binding_attempt_number": {
          "type": "integer",
          "minimum": 1
        },
        "fallback_index": {
          "type": "integer",
          "minimum": 0
        },
        "binding_id": {
          "type": "string",
          "minLength": 1
        },
        "is_retry": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "succeeded",
            "failed",
            "timed_out",
            "backpressured",
            "canceled"
          ]
        },
        "failure_kind": {
          "type": ["string", "null"],
          "enum": [
            "routing",
            "dispatch",
            "execution",
            "timeout",
            "backpressure",
            "canceled",
            "contract",
            null
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "started_at": {
          "type": "string",
          "minLength": 1
        },
        "finished_at": {
          "type": "string",
          "minLength": 1
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "trace_span_id": {
          "type": ["string", "null"]
        },
        "actual_implementation_id": {
          "type": ["string", "null"]
        },
        "actual_service_id": {
          "type": ["string", "null"]
        },
        "actual_runtime": {
          "type": ["string", "null"],
          "enum": [
            "python_local",
            "python_service",
            "rust_service",
            "external_service",
            null
          ]
        },
        "error": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              }
            }
          },
          "then": {
            "properties": {
              "failure_kind": {
                "type": "null"
              },
              "error": {
                "type": "null"
              },
              "retryable": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "status": {
                  "const": "succeeded"
                }
              }
            }
          },
          "then": {
            "properties": {
              "failure_kind": {
                "type": "string"
              },
              "error": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "timed_out"
              }
            }
          },
          "then": {
            "properties": {
              "failure_kind": {
                "const": "timeout"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "backpressured"
              }
            }
          },
          "then": {
            "properties": {
              "failure_kind": {
                "const": "backpressure"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "canceled"
              }
            }
          },
          "then": {
            "properties": {
              "failure_kind": {
                "const": "canceled"
              }
            }
          }
        }
      ]
    }
  }
}
