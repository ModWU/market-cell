{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/execution_plan_validation.schema.json",
  "title": "MarketCell ExecutionPlanValidation",
  "type": "object",
  "required": [
    "error_type",
    "plan_id",
    "issues",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "error_type": {
      "const": "execution_plan_validation"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "schema_version": {
      "const": "execution_plan_validation.v1"
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": [
        "code",
        "message",
        "node_id",
        "binding_id",
        "dependency_id"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "duplicate_node_id",
            "duplicate_binding_id",
            "missing_root",
            "invalid_root_role",
            "unexpected_root_role",
            "missing_dependency",
            "duplicate_dependency",
            "self_dependency",
            "leaf_has_dependencies",
            "missing_binding",
            "binding_cell_mismatch",
            "binding_formula_mismatch",
            "unused_binding",
            "cycle_detected",
            "unreachable_node"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": ["string", "null"]
        },
        "binding_id": {
          "type": ["string", "null"]
        },
        "dependency_id": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
