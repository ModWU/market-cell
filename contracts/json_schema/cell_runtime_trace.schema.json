{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/cell_runtime_trace.schema.json",
  "title": "MarketCell CellRuntimeTrace",
  "type": "object",
  "required": [
    "trace_id",
    "span_id",
    "run_id",
    "node_id",
    "cell_id",
    "formula_version",
    "status",
    "started_at",
    "finished_at",
    "duration_ms",
    "schema_version",
    "plan_id",
    "implementation_id",
    "service_id",
    "runtime",
    "retry_count",
    "error",
    "parent_span_id",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "span_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "cell_id": {
      "type": "string",
      "minLength": 1
    },
    "formula_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["succeeded", "failed", "skipped"]
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "finished_at": {
      "type": "string",
      "minLength": 1
    },
    "duration_ms": {
      "type": "number",
      "minimum": 0
    },
    "schema_version": {
      "const": "cell_runtime_trace.v1"
    },
    "plan_id": {
      "type": ["string", "null"]
    },
    "implementation_id": {
      "type": ["string", "null"]
    },
    "service_id": {
      "type": ["string", "null"]
    },
    "runtime": {
      "type": ["string", "null"],
      "enum": ["python_local", "python_service", "rust_service", "external_service", null]
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "error": {
      "type": ["string", "null"]
    },
    "parent_span_id": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
