{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/input_reference.schema.json",
  "title": "MarketCell InputReference",
  "type": "object",
  "required": [
    "reference_id",
    "snapshot_id",
    "input_kind",
    "uri",
    "content_hash",
    "data_version",
    "source",
    "target",
    "horizon",
    "payload_size_bytes",
    "schema_version",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "reference_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "input_kind": {
      "enum": ["analysis_request", "candle_batch", "funding_open_interest_snapshot", "feature_snapshot", "order_book_snapshot"]
    },
    "uri": {"type": "string", "minLength": 1},
    "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "data_version": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "horizon": {"type": "string", "minLength": 1},
    "payload_size_bytes": {"type": "integer", "minimum": 2},
    "schema_version": {"const": "input_reference.v1"},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
