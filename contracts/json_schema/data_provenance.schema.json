{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketcell.local/schemas/data_provenance.schema.json",
  "title": "MarketCell DataProvenance",
  "type": "object",
  "required": [
    "source_provider",
    "venue",
    "market_type",
    "event_time_ms",
    "fetched_at_ms",
    "sequence",
    "source_event_id",
    "quality_flags",
    "schema_version",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "source_provider": {"type": "string", "minLength": 1},
    "venue": {"type": "string", "minLength": 1},
    "market_type": {
      "enum": ["spot", "perpetual_future", "futures", "index", "unknown"]
    },
    "event_time_ms": {"type": "integer", "minimum": 0},
    "fetched_at_ms": {"type": "integer", "minimum": 0},
    "sequence": {"type": ["integer", "null"], "minimum": 0},
    "source_event_id": {"type": ["string", "null"], "minLength": 1},
    "quality_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "schema_version": {"const": "data_provenance.v1"},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
